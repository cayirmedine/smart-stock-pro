# ------------------------------------------------------------------------------
# APP
# ------------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=smart-stock-pro
APP_PORT=3000
APP_HOST=0.0.0.0
LOG_LEVEL=debug
TZ=Europe/Istanbul

# ------------------------------------------------------------------------------
# DATABASE (PostgreSQL + Prisma)
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5433
DB_NAME=smart_stock_db
DB_USER=postgres
DB_PASSWORD=change_me
DB_SCHEMA=public

DATABASE_URL="postgresql://postgres:change_me@localhost:5433/smart_stock_db?schema=public&connection_limit=10&pool_timeout=20"
DIRECT_URL="postgresql://postgres:change_me@localhost:5433/smart_stock_db?schema=public"

# ------------------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_URL="redis://:change_me@localhost:6379"

# ------------------------------------------------------------------------------
# AUTH / SECURITY
# ------------------------------------------------------------------------------
JWT_ACCESS_SECRET=change_me_access_secret_very_long_random
JWT_REFRESH_SECRET=change_me_refresh_secret_very_long_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ------------------------------------------------------------------------------
# RATE LIMIT
# ------------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ------------------------------------------------------------------------------
# PRISMA / DEBUG
# ------------------------------------------------------------------------------
PRISMA_LOG_QUERIES=false
PRISMA_LOG_WARNINGS=true
PRISMA_LOG_ERRORS=true

# ------------------------------------------------------------------------------
# SENTRY
# ------------------------------------------------------------------------------
SENTRY_DSN=change_me_sentry_dsn
